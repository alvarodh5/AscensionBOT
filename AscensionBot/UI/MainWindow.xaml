<Window x:Class="AscensionBot.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AscensionBot.UI"
        mc:Ignorable="d"
        Title="Ascension Bot" Width="440" Height="600" MinWidth="360" MinHeight="400">
    <Window.DataContext>
        <local:MainViewModel />
    </Window.DataContext>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Profile selector -->
        <DockPanel Grid.Row="0" LastChildFill="True" Margin="0,0,0,8">
            <Label Content="Perfil:" VerticalAlignment="Center" DockPanel.Dock="Left"/>
            <ComboBox VerticalContentAlignment="Center"
                      SelectedItem="{Binding CurrentBot, Mode=TwoWay}"
                      ItemsSource="{Binding Bots, Mode=OneWay}"
                      IsEnabled="{Binding CurrentBotEnabled}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Name}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </DockPanel>

        <!-- Start / Stop / Test -->
        <UniformGrid Grid.Row="1" Rows="1" Columns="3" Margin="0,0,0,8">
            <Button Content="Start" Margin="2" Padding="0,6"
                    Command="{Binding StartCommand}" IsEnabled="{Binding StartCommandEnabled}"/>
            <Button Content="Stop" Margin="2" Padding="0,6"
                    Command="{Binding StopCommand}" IsEnabled="{Binding StopCommandEnabled}"/>
            <Button Content="Test" Margin="2" Padding="0,6"
                    Command="{Binding TestCommand}"/>
        </UniformGrid>

        <!-- Console output (must stay named "Console" — MainWindow.xaml.cs scrolls it) -->
        <ScrollViewer Name="Console" Grid.Row="2" Padding="6" Background="#1E1E1E">
            <ItemsControl ItemsSource="{Binding ConsoleOutput, Mode=OneWay}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" Foreground="#DDDDDD" TextWrapping="Wrap"
                                   FontFamily="Consolas" FontSize="11"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>
